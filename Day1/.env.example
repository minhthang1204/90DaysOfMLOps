# ── MLflow ────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=house-price-prediction

# ── App Config ────────────────────────────
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# ── Paths ─────────────────────────────────
MODEL_PATH=artifacts/best_model.pkl
SCALER_PATH=artifacts/scaler.pkl
METRICS_PATH=artifacts/metrics.json

# ── Model Training ────────────────────────
TEST_SIZE=0.2
RANDOM_STATE=42
N_ESTIMATORS=100